{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "App": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Jwt": {
    "Issuer": "phoenix-emballages",
    "Audience": "phoenix-emballages-clients",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
}
